    "lint:all": "nx run-many --target=lint --all",
    "graph": "nx graph"
  },
  "cli": {
    "packageManager": "yarn"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
