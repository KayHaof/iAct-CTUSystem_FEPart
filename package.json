{
  "name": "my-mfe-project",
  "version": "0.0.0",
  "scripts": {
    "start": "nx serve shell",
    "start:all": "nx run-many --target=serve --all --parallel=3",
    "start:shellStudent": "yarn nx run-many --target=serve --projects=shell,mfe-student",
    "start:shellAdmin": "yarn nx run-many --target=serve --projects=shell,mfe-admin",
    "start:student": "nx serve mfe-student",
    "start:admin": "nx serve mfe-admin",
    "build:all": "nx run-many --target=build --all",
